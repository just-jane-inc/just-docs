---
import {CardGrid} from "@astrojs/starlight/components";
---
<redeems-index />

<script>
    import { scrollToUrlFragment } from "../viewport.ts";

    // Fetch the redeems during runtime, not during build time.
    const response = await fetch('https://api.bahms.org/v1/twitch/redeems');
    const redeems = await response.json();

    if (typeof redeems !== 'object') {
        console.error('Could not load redeems from API endpoint');
    }

    // Very naive way to turn the redeem title into a URL slug.
    const createSlug = (title: string): string => title
        .toLowerCase()
        .replaceAll(' ', '-');

    const decimalFormatter = new Intl.NumberFormat('en-US', { style: 'decimal' });

    class RedeemsIndexCard extends HTMLElement {
        connectedCallback() {
            const { title, cost, icon, color, isPaused } = this.dataset;

            if (!title) {
                throw new Error('Redeem requires a title');
            }

            if (!cost) {
                throw new Error(`Redeem "${title}" requires channel points`);
            }

            if (!icon) {
                throw new Error(`Redeem "${title}" requires icon URL`);
            }

            if (!color) {
                throw new Error(`Redeem "${title}" requires a color`);
            }

            this.title = title;

            // Configure the icon color for the current redeem.
            this.style.setProperty('--redeem-color', `${color}`);

            // Reflect the paused state.
            if (isPaused) {
                this.classList.add('paused');
            }

            // Create an anchor that navigates to the full description of the redeem.
            const anchor = document.createElement('a');
            anchor.setAttribute('href', `#${createSlug(title)}`);
            anchor.setAttribute('title', title);

            // Create the card that visually forms the entry in the index.
            const card = document.createElement('article');

            const redeemTitle = document.createElement('p');
            redeemTitle.classList.add('redeem-title');
            redeemTitle.innerText = title;
            card.append(redeemTitle);

            const redeemIcon = document.createElement('span');
            redeemIcon.classList.add('redeem-icon');
            redeemTitle.prepend(redeemIcon);

            const redeemImage = document.createElement('img');
            redeemImage.setAttribute('src', icon);
            redeemImage.setAttribute('alt', title);
            redeemIcon.append(redeemImage);

            const redeemChannelPoints = document.createElement('p');
            redeemChannelPoints.innerText = 'Channel points: ';
            const channelPointsValue = document.createElement('code');
            channelPointsValue.innerText = decimalFormatter.format(cost);
            redeemChannelPoints.append(channelPointsValue);
            card.append(redeemChannelPoints);

            // Append the anchor to the current index entry.
            anchor.append(card);
            this.append(anchor);
        }
    }

    class RedeemsIndex extends HTMLElement {
        connectedCallback() {
            // Reset the index.
            this.innerHTML = '';
            const sortedRedeems = redeems.sort(({cost: costA}, {cost: costB}) => costA - costB);

            // Populate the index.
            for (const {
                id,
                title,
                cost,
                image: { 'url-4x': icon },
                'background-color': color,
                'is-paused': isPaused,
            } of sortedRedeems) {
                const card = document.createElement('redeems-index-card');
                card.id = `redeem-${id}-index-card`;
                card.dataset.title = title;
                card.dataset.cost = cost;
                card.dataset.icon = icon;
                card.dataset.color = color;
                card.dataset.isPaused = isPaused ? 'paused' : '';

                this.append(card);
            }

            // Scroll to the section of documentation selected in the URL.
            scrollToUrlFragment();
        }
    }

    // Initialize the components if the API produced a valid response.
    if (typeof redeems === 'object' && Array.from(redeems).length > 0) {
        customElements.define('redeems-index-card', RedeemsIndexCard);
        customElements.define('redeems-index', RedeemsIndex);
    }
</script>

<style>
    redeems-index {
        display: grid;
        grid-template-columns: 100%;
        gap: 1rem;

        redeems-index-card {
            --redeem-color: var(--sl-color-text-accent);

            &.paused {
                opacity: .3;
            }

            a {
                text-decoration-line: none;
                color: var(--sl-color-white);
            }

            article {
                --redeem-background-alpha: 0;
                --redeem-icon-background-alpha: 0.3;
                border: 1px solid var(--sl-color-gray-5);
                padding: clamp(1rem, calc(0.125rem + 3vw), 2.5rem);
                flex-direction: column;
                gap: clamp(0.5rem, calc(0.125rem + 1vw), 1rem);
                text-decoration-line: none;

                background-color: color(
                    from var(--redeem-color)
                    srgb
                    r g b / var(--redeem-background-alpha)
                );

                .redeem-title {
                    font-size: 1.3em;
                    font-weight: 700;
                }

                .redeem-icon {
                    display: inline-block;
                    background-color: color(
                        from var(--redeem-color)
                        srgb
                        r g b / var(--redeem-icon-background-alpha)
                    );

                    border: 1px solid var(--redeem-color);
                    border-radius: 3px;

                    text-align: center;

                    padding: 4px;
                    margin-right: .5em;
                    line-height: 12px;

                    img {
                        --size: 20px;
                        display: inline-block;
                        max-width: var(--size);
                        max-height: var(--size);
                    }
                }
            }

            &:hover {
                a {
                    text-decoration: underline;
                }

                article {
                    --redeem-icon-background-alpha: 0;
                    --redeem-background-alpha: 0.3;
                    border-color: color(
                        from var(--redeem-color)
                        srgb
                        r g b / 1
                    );
                    border-radius: 3px;

                    .redeem-icon {
                        border-color: var(--sl-color-text);
                    }
                }
            }
        }
    }

    redeems-index > :global(*) {
        margin-top: 0 !important;
    }

    @media (min-width: 50rem) {
        redeems-index {
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }
    }
</style>
---
import {
    type RedeemsSection,
    type RedeemsSelectorConfiguration,
    resolveRedeemsSection
} from "../redeems.ts";

interface Props {
    sections: RedeemsSection[];
}

const { sections = [] } = Astro.props;

const preparedSections = await Promise.all(sections.map(resolveRedeemsSection));
---
<redeems-index />

{preparedSections.map(
    ({title, description, redeems: { onSelect, postSelect }}) => <redeems-section
        data-on-select={JSON.stringify(onSelect)}
        data-post-select={JSON.stringify(postSelect)}
        class:list={['empty']}
    >
        <h2>{title}</h2>
        <div set:html={description} />
    </redeems-section>
)}

<script>
    import { scrollToUrlFragment } from "../viewport.ts";

    // Fetch the redeems during runtime, not during build time.
    const response = await fetch('https://api.bahms.org/v1/twitch/redeems');
    let redeems = response.ok ? await response.json() : undefined;

    if (typeof redeems !== 'object') {
        console.error('Could not load redeems from API endpoint');
    }

    // Very naive way to turn the redeem title into a URL slug.
    const createSlug = (title) => String(title)
        .toLowerCase()
        .replaceAll(' ', '-');

    const decimalFormatter = new Intl.NumberFormat('en-US', { style: 'decimal' });

    class RedeemsIndexCard extends HTMLElement {
        connectedCallback() {
            const { title, cost, icon, color, isPaused } = this.dataset;

            if (!title) {
                throw new Error('Redeem requires a title');
            }

            if (!cost) {
                throw new Error(`Redeem "${title}" requires channel points`);
            }

            if (!icon) {
                throw new Error(`Redeem "${title}" requires icon URL`);
            }

            if (!color) {
                throw new Error(`Redeem "${title}" requires a color`);
            }

            this.title = title;

            // Configure the icon color for the current redeem.
            this.style.setProperty('--redeem-color', `${color}`);

            // Reflect the paused state.
            if (isPaused) {
                this.classList.add('paused');
            }

            // Create an anchor that navigates to the full description of the redeem.
            const anchor = document.createElement('a');
            anchor.setAttribute('href', `#${createSlug(title)}`);
            anchor.setAttribute('title', title);

            // Create the card that visually forms the entry in the index.
            const card = document.createElement('article');

            const redeemTitle = document.createElement('p');
            redeemTitle.classList.add('redeem-title');
            redeemTitle.innerText = title;
            card.append(redeemTitle);

            const redeemIcon = document.createElement('span');
            redeemIcon.classList.add('redeem-icon');
            redeemTitle.prepend(redeemIcon);

            const redeemImage = document.createElement('img');
            redeemImage.setAttribute('src', icon);
            redeemImage.setAttribute('alt', title);
            redeemIcon.append(redeemImage);

            const redeemChannelPoints = document.createElement('p');
            redeemChannelPoints.innerText = 'Channel points: ';
            const channelPointsValue = document.createElement('code');
            channelPointsValue.innerText = decimalFormatter.format(cost);
            redeemChannelPoints.append(channelPointsValue);
            card.append(redeemChannelPoints);

            // Append the anchor to the current index entry.
            anchor.append(card);
            this.append(anchor);
        }
    }

    class RedeemsIndex extends HTMLElement {
        connectedCallback() {
            // Reset the index.
            this.innerHTML = '';
            const sortedRedeems = redeems.sort(({cost: costA}, {cost: costB}) => costA - costB);

            // Populate the index.
            for (const {
                id,
                title,
                cost,
                image: { 'url-4x': icon },
                'background-color': color,
                'is-paused': isPaused,
            } of sortedRedeems) {
                const card = document.createElement('redeems-index-card');
                card.id = `redeem-${id}-index-card`;
                card.dataset.title = title;
                card.dataset.cost = cost;
                card.dataset.icon = icon;
                card.dataset.color = color;
                card.dataset.isPaused = isPaused ? 'paused' : '';

                this.append(card);
            }
        }
    }

    // @todo Solve this by wrapping the redeem sections in a redeem sections list.
    //   then, copy the redeems for that list and only consume within the list.
    //   This should also address the naive post-select logic.
    const consumeRedeems = (selector) => {
        const matcher = new RegExp(`^${selector}$`);
        const result = Array.from(redeems).filter(({id}) => matcher.test(id));
        const remove = result.map(({id}) => id);

        redeems = redeems.filter(({id}) => !remove.includes(id));

        return result;
    }

    class RedeemCard extends HTMLElement {
        connectedCallback() {
            const { title, description, icon, cost } = this.dataset;

            if (!title) {
                throw new Error('Redeem requires a title');
            }

            if (!description) {
                throw new Error(`Redeem ${title} requires a description`);
            }

            if (!icon) {
                throw new Error(`Redeem ${title} requires an icon`);
            }

            if (!cost) {
                throw new Error(`Redeem ${title} requires a cost`);
            }

            const headingAnchor = document.createElement('a');
            headingAnchor.href = `#${createSlug(title)}`;

            const figure = document.createElement('figure');
            const image = document.createElement('img');
            image.alt = title;
            image.src = icon;

            figure.append(image);
            headingAnchor.append(figure);

            const heading = document.createElement('h3');
            heading.innerText = title;
            heading.id = createSlug(title);
            headingAnchor.append(heading);

            const channelPointsValue = document.createElement('code');
            channelPointsValue.innerText = decimalFormatter.format(cost);
            const channelPoints = document.createElement('p');
            channelPoints.innerText = ' channel points';
            channelPoints.prepend(channelPointsValue);
            headingAnchor.append(channelPoints);

            this.append(headingAnchor);

            const descriptionContainer = document.createElement('div');
            descriptionContainer.innerHTML = description;
            this.append(descriptionContainer);
        }
    }

    // @todo Debounce the post selection step, so it waits for the other
    // redeems sections.
    class RedeemsSection extends HTMLElement {
        connectedCallback() {
            const { onSelect, postSelect } = this.dataset;

            const heading = this.querySelector('h2');

            // Make sure the heading has an ID.
            if (heading && !heading.id) {
                heading.id = createSlug(heading.innerText);
            }

            const selectionConfig = JSON.parse(onSelect ?? '{}');
            const postSelectionConfig = JSON.parse(postSelect ?? '{}');

            const sectionRedeems = [];

            // Do the initial selection.
            for (const selector of Object.keys(selectionConfig)) {
                sectionRedeems.push(
                    ...consumeRedeems(selector).map(
                        (redeem) => ({...redeem, ...selectionConfig[selector]})
                    )
                );
            }
            // Do the post selection.
            // N.B.: In the current implementation this is too naive.
            for (const selector of Object.keys(postSelectionConfig)) {
                sectionRedeems.push(
                    ...consumeRedeems(selector).map(
                        (redeem) => ({...redeem, ...postSelectionConfig[selector]})
                    )
                );
            }

            for (const {
                id,
                title,
                description,
                prompt,
                cost,
                'is-paused': isPaused,
                'background-color': color,
                image: { 'url-4x': icon },
            } of sectionRedeems) {
                const redeem = document.createElement('redeem-card');
                redeem.id = `redeem-${id}`;
                redeem.dataset.title = title;
                redeem.dataset.description = description || prompt;
                redeem.dataset.icon = icon;
                redeem.dataset.cost = cost;

                if (isPaused) {
                    redeem.classList.add('paused');
                }

                redeem.style.setProperty('--redeem-color', color);

                this.append(redeem);
            }

            if (sectionRedeems.length > 0) {
                this.classList.remove('empty');

                // Scroll to the section of documentation selected in the URL.
                scrollToUrlFragment();
            } else {
                this.remove();
            }
        }
    }

    // Initialize the components if the API produced a valid response.
    if (typeof redeems === 'object' && Array.from(redeems).length > 0) {
        customElements.define('redeems-index-card', RedeemsIndexCard);
        customElements.define('redeems-index', RedeemsIndex);
        customElements.define('redeems-section', RedeemsSection);
        customElements.define('redeem-card', RedeemCard);
    }
</script>

<style>
    redeems-index {
        display: grid;
        grid-template-columns: 100%;
        gap: 1rem;

        redeems-index-card {
            --redeem-color: var(--sl-color-text-accent);

            &.paused {
                opacity: .3;
            }

            a {
                text-decoration-line: none;
                color: var(--sl-color-white);
            }

            article {
                --redeem-background-alpha: 0;
                --redeem-icon-background-alpha: 0.3;
                border: 1px solid var(--sl-color-gray-5);
                padding: clamp(1rem, calc(0.125rem + 3vw), 2.5rem);
                flex-direction: column;
                gap: clamp(0.5rem, calc(0.125rem + 1vw), 1rem);
                text-decoration-line: none;

                background-color: color(
                    from var(--redeem-color)
                    srgb
                    r g b / var(--redeem-background-alpha)
                );

                .redeem-title {
                    font-size: 1.3em;
                    font-weight: 700;
                }

                .redeem-icon {
                    display: inline-block;
                    background-color: color(
                        from var(--redeem-color)
                        srgb
                        r g b / var(--redeem-icon-background-alpha)
                    );

                    border: 1px solid var(--redeem-color);
                    border-radius: 3px;

                    text-align: center;

                    padding: 4px;
                    margin-right: .5em;
                    line-height: 12px;

                    img {
                        --size: 20px;
                        display: inline-block;
                        max-width: var(--size);
                        max-height: var(--size);
                    }
                }
            }

            &:hover {
                a {
                    text-decoration: underline;
                }

                article {
                    --redeem-icon-background-alpha: 0;
                    --redeem-background-alpha: 0.3;
                    border-color: color(
                        from var(--redeem-color)
                        srgb
                        r g b / 1
                    );
                    border-radius: 3px;

                    .redeem-icon {
                        border-color: var(--sl-color-text);
                    }
                }
            }
        }
    }

    redeems-index > :global(*) {
        margin-top: 0 !important;
    }

    @media (min-width: 50rem) {
        redeems-index {
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }
    }

    redeems-section + redeems-section {
        margin-top: 4rem;
    }

    redeems-section {
        display: block;
        margin-top: 2rem;

        &.empty {
            display: none;
        }

        redeem-card {
            --redeem-color: var(--sl-color-text-accent);
            --redeem-border-alpha: 0.3;
            --padding: 2rem;

            display: block;
            background-color: var(--sl-color-bg-sidebar);
            border: 3px solid color(
                from var(--redeem-color)
                srgb
                r g b / var(--redeem-border-alpha)
            );

            margin-top: 2.6rem;
            padding: var(--padding);
            border-radius: .5rem;

            position: relative;

            figure {
                padding-left: 3px;
                background-color: color(
                    from var(--redeem-color) srgb r g b / var(--redeem-border-alpha)
                );
            }

            > a {
                display: block;
                width: 100%;
                text-decoration: none;
                color: inherit;
                margin-bottom: 2em;

                &:hover {
                    h3 {
                        text-decoration: underline;
                    }
                }

                h3 {
                    margin-top: 0;
                }

                figure {
                    float: right;
                    padding: 1em;
                    margin: 0 0 var(--padding) var(--padding);
                    height: 66px;
                    border-radius: .5em;

                    img {
                        height: 100%;
                        aspect-ratio: auto;
                    }
                }
            }

            > div {
                clear: both;
            }

            &.paused {
                opacity: .3;
            }

            &:hover {
                --redeem-border-alpha: 0.6;
                box-shadow: 0 0 .5rem 0 color(
                    from var(--sl-color-text)
                    srgb
                    r g b / var(--redeem-border-alpha)
                );
            }
        }
    }
</style>
---
import SpriteImage from "./SpriteImage.astro";
import sheet from '../../../public/ship-sheet.png';

interface Props {
    frame: 1|2|3|4|5|6|7;
}

const { frame } = Astro.props;
const width = 80;
const x = (frame - 1) * width;
const title = `Spritesheet frame section from ${x}px to ${(x + width - 1)}px`
---
<SpriteImage
    sheet={sheet}
    width={width}
    height={45}
    x={x}
    title={title}
/>
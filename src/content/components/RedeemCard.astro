---
import {AstroError} from "astro/errors";

interface Props {
    title: string;
    anchor: string;
    channelPoints: number|string;
    iconBackgroundColor: string;
    iconUrl: string;
}

const { title, anchor, channelPoints, iconBackgroundColor, iconUrl } = Astro.props;

if (!title) {
    throw new AstroError('Redeem requires a title');
}

if (!anchor) {
    throw new AstroError('Redeem requires an anchor');
}

if (!channelPoints) {
    throw new AstroError('Redeem requires channel points / formula');
}

if (!iconBackgroundColor.match(/rgb\(\d{1,3},\s*\d{1,3},\s*\d{1,3}\)/)) {
    throw new AstroError('Redeem requires icon background color in rgb() notation');
}

if (!iconUrl) {
    throw new AstroError('Redeem requires icon URL');
}
---
<a class="redeem-anchor" href={anchor}>
    <article class="redeem-card">
        <p class="redeem-title">
            <span class="redeem-icon"><img alt={title} src={iconUrl} /></span>
            <span set:text={title} />
        </p>
        <p class="redeem-channel-points">
            Channel points:
            <code set:html={channelPoints} />
        </p>
    </article>
</a>

<style define:vars={{ 'redeem-icon-background-color': iconBackgroundColor }}>
    .redeem-anchor {
        text-decoration-line: none;
        color: var(--sl-color-white);
    }
    .redeem-anchor:hover {
        text-decoration: underline;
    }

    .redeem-card {
        border: 1px solid var(--sl-color-gray-5);
        background-color: var(--sl-color-black);
        padding: clamp(1rem, calc(0.125rem + 3vw), 2.5rem);
        flex-direction: column;
        gap: clamp(0.5rem, calc(0.125rem + 1vw), 1rem);
        text-decoration-line: none;
    }

    .redeem-title {
        font-size: 1.3em;
        font-weight: 700;
    }

    .redeem-icon {
        --size: 1.6em;
        --padding: .1em;

        display: inline-block;
        width: var(--size);
        height: var(--size);
        background-color: color(from var(--redeem-icon-background-color) srgb r g b / 0.3);
        padding: var(--padding);
        line-height: var(--size);
        margin-right: .5em;

        border: 1px solid var(--redeem-icon-background-color);
        border-radius: 3px;

        text-align: center;

        img {
            display: inline-block;
            margin: auto;
            max-width: calc(100% - var(--padding));
            max-height: calc(100% - var(--padding));
        }
    }

    .redeem-card:hover {
        .redeem-icon {
            background-color: color(from var(--redeem-icon-background-color) srgb r g b / 0.6);
        }
    }
</style>